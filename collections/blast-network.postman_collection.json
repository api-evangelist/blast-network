  "info": {
    "_postman_id": "c90b13b0-5689-4ade-a57b-646b8fb71c94",
    "name": "Blast Network JSON-RPC",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "Public Ethereum-compatible JSON-RPC endpoint for the Blast Layer 2\nnetwork (OP Stack derived). Mainnet is chain ID 81457 at\nhttps://rpc.blast.io; Sepolia testnet is chain ID 168587773 at\nhttps://sepolia.blast.io. This OpenAPI describes the JSON-RPC\ntransport: all calls are HTTP POSTs to `/` with a JSON-RPC 2.0\nenvelope and a method-specific `params` array.\n\n\nContact Support:\n Name: Blast",
      "type": "text/plain"
    }
  }
